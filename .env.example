# Runtime server
HOST=0.0.0.0
PORT=7890
API_HOST=0.0.0.0
API_PORT=7892
API_BASE_URL=http://127.0.0.1:7892

# Production API and embedded database
AUTH_SECRET=replace-with-a-long-random-secret
STORAGE_PATH=/var/opt/i-remember.fr/assets
STORAGE_PUBLIC_BASE_URL=/uploads
API_MAX_JSON_BODY_BYTES=12582912
POSTGRES_DB=i_remember
POSTGRES_PORT=5432

# Temporary public archive runtime
I_REMEMBER_DATA_DIR=/var/opt/i-remember.fr
I_REMEMBER_DEFAULT_LANGUAGE=en
I_REMEMBER_ANONYMOUS_SUBMISSIONS=true
I_REMEMBER_AUTO_APPROVE_SUBMISSIONS=true
I_REMEMBER_MAX_UPLOAD_BYTES=8388608
I_REMEMBER_MAX_IMAGE_PIXELS=30000000
I_REMEMBER_SEED_ARCHIVE_DATA=false
I_REMEMBER_SEED_STARTER_CONTENT=false

# Self-hosted Umami tracking
UMAMI_SRC=https://umami.example.com/script.js
UMAMI_WEBSITE_ID=replace-with-umami-website-id

# DockerHub release
DOCKERHUB_IMAGE=zerostwo/i-remember.fr
TAG=latest
