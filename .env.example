# Runtime server
HOST=0.0.0.0
PORT=8080

# Memos-style local backend
I_REMEMBER_DATA_DIR=/var/opt/i-remember
I_REMEMBER_DEFAULT_LANGUAGE=en
I_REMEMBER_ANONYMOUS_SUBMISSIONS=true
I_REMEMBER_AUTO_APPROVE_SUBMISSIONS=false
I_REMEMBER_MAX_UPLOAD_BYTES=8388608
I_REMEMBER_MAX_IMAGE_PIXELS=30000000

# Admin
I_REMEMBER_ADMIN_EMAIL=admin@i-remember.fr
I_REMEMBER_ADMIN_PASSWORD=change-this-password

# Self-hosted Umami tracking
UMAMI_SRC=https://umami.example.com/script.js
UMAMI_WEBSITE_ID=replace-with-umami-website-id

# DockerHub release
DOCKERHUB_IMAGE=docker.io/your-namespace/i-remember-fr
TAG=latest
