generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
  ANONYMOUS
}

enum Visibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum MemoryStatus {
  NORMAL
  PENDING
  ARCHIVED
  REJECTED
}

enum CommentStatus {
  NORMAL
  PENDING
  ARCHIVED
  REJECTED
}

enum PageStatus {
  PUBLISHED
  DRAFT
  ARCHIVED
}

enum MenuItemType {
  PAGE
  MEMORY
  SEARCH
  EXTERNAL
  TERMS
  CREDITS
  LANGUAGE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  memories     Memory[] @relation("MemoryAuthor")

  @@map("users")
}

model Memory {
  id             String       @id @default(cuid())
  publicId       String       @unique @map("public_id")
  title          String
  content        String
  excerpt        String?
  authorId       String?      @map("author_id")
  authorName     String?      @map("author_name")
  visibility     Visibility   @default(PUBLIC)
  status         MemoryStatus @default(PENDING)
  latitude       Float?
  longitude      Float?
  emotion        String?
  metadata       Json?
  embedding      Json?
  aiSummary      String?      @map("ai_summary")
  knowledgeGraph Json?        @map("knowledge_graph")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  author         User?        @relation("MemoryAuthor", fields: [authorId], references: [id])
  attachments    Attachment[]
  tags           MemoryTag[]
  comments       Comment[]

  @@index([visibility, status, createdAt])
  @@map("memories")
}

model Attachment {
  id        String   @id @default(cuid())
  memoryId  String   @map("memory_id")
  url       String
  type      String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  memory    Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId])
  @@map("attachments")
}

model Tag {
  id        String      @id @default(cuid())
  name      String      @unique
  slug      String      @unique
  createdAt DateTime    @default(now()) @map("created_at")
  memories  MemoryTag[]

  @@map("tags")
}

model MemoryTag {
  memoryId  String   @map("memory_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")
  memory    Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([memoryId, tagId])
  @@map("memory_tags")
}

model Comment {
  id          String        @id @default(cuid())
  memoryId    String?       @map("memory_id")
  authorName  String        @default("Anonymous") @map("author_name")
  authorEmail String?       @map("author_email")
  content     String
  status      CommentStatus @default(PENDING)
  metadata    Json?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  memory      Memory?       @relation(fields: [memoryId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([memoryId])
  @@map("comments")
}

model Page {
  id             String     @id @default(cuid())
  slug           String
  language       String     @default("en") @map("language_code")
  title          String
  excerpt        String?
  bodyMarkdown   String     @default("") @map("body_markdown")
  status         PageStatus @default(DRAFT)
  linkedMemoryId String?    @map("linked_memory_id")
  metadata       Json?
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@unique([language, slug])
  @@index([status, updatedAt])
  @@map("pages")
}

model MenuItem {
  id          String       @id @default(cuid())
  uid         String       @default(cuid())
  language    String       @default("en") @map("language_code")
  label       String
  type        MenuItemType @map("item_type")
  targetValue String?      @map("target_value")
  url         String?
  position    Int          @default(0)
  isVisible   Boolean      @default(true) @map("is_visible")
  opensNewTab Boolean      @default(false) @map("opens_new_tab")
  metadata    Json?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@unique([language, uid])
  @@index([language, position])
  @@map("menu_items")
}

model AppSetting {
  key       String   @id
  value     Json?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
