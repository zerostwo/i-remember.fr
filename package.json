{
  "name": "i-remember-fr",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@i-remember/web --filter=@i-remember/api",
    "build": "turbo run build --filter=@i-remember/database --filter=@i-remember/api && vite build",
    "typecheck": "turbo run typecheck --filter=@i-remember/database --filter=@i-remember/api --filter=@i-remember/admin --filter=@i-remember/web --filter=@i-remember/types",
    "lint": "eslint .",
    "format": "prettier --check .",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server.mjs",
    "test": "turbo run test --filter=@i-remember/database --filter=@i-remember/api --filter=@i-remember/admin --filter=@i-remember/web --filter=@i-remember/memory-engine --filter=@i-remember/types --filter=@i-remember/storage --filter=@i-remember/ui --filter=@i-remember/config && node scripts/check-api-v1.mjs && node src/admin/v1-memory.check.mjs && node src/admin/v1-assets.check.mjs && node src/admin/v1-content.check.mjs && node scripts/check-server-proxy.mjs",
    "web:dev": "vite --host 127.0.0.1",
    "web:build": "vite build",
    "db:generate": "pnpm --filter @i-remember/database generate",
    "db:migrate": "pnpm --filter @i-remember/database migrate",
    "docker:build": "docker compose build",
    "docker:push": "docker compose push"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.22.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@vitejs/plugin-react": "^5.1.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^10.6.0",
    "lucide-react": "^1.23.0",
    "prettier": "^3.9.4",
    "prisma": "^7.8.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "turbo": "^2.10.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.3"
  }
}
